	)
	(text "Adafruit estimate 20mA for typical use\n20mA * 4 = 80mA LED load"
		(exclude_from_sim no)
		(at 78.232 80.264 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "69182333-4d86-42c0-9555-1f0ef284abc4")
	)
	(text "This will connect to a pigtail for the LRA. \nI intend to hand-solder thin wires to the \nactuator, then join those to slightly thicker \nwires which are crimped to the JST connector"
