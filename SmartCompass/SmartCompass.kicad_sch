	(text "The product here is a smart compass. \n\nIt has GNSS and an IMU for positioning in the world,\nand LoRa and BLE for comms. \n\nIt uses a ring of RGB LED, an e-ink display, and haptic \nfeedback for user interaction, along with 3 buttons. \n\nBattery powered, with USB-C charging."
		(exclude_from_sim no)
		(at 239.014 30.226 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "53b22426-9665-467f-92e3-fe8c21a5a1e3")
	)
	(text "LOW FREQUENCY PINS\n(<10kHz)\n\nP0.28-0.31, P0.02, P0.03, P0.09, P0.10\nP1.01-1.07, P1.10-1.15"
		(exclude_from_sim no)
		(at 34.798 119.634 0)
